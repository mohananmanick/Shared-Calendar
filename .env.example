# Google OAuth (from Google Cloud Console)
GOOGLE_CLIENT_ID=your-client-id-here
GOOGLE_CLIENT_SECRET=your-client-secret-here

# Google Calendar IDs (usually Gmail addresses)
CALENDAR_ID_1=your-email@gmail.com
CALENDAR_ID_2=partner-email@gmail.com

# Display names for each person
PERSON_1_NAME=You
PERSON_2_NAME=Partner

# Google OAuth tokens (obtained after login flow)
GOOGLE_ACCESS_TOKEN=
GOOGLE_REFRESH_TOKEN=

# Telegram Bot
TELEGRAM_BOT_TOKEN=your-telegram-bot-token

# Anthropic API key (for the Telegram bot's AI parsing)
ANTHROPIC_API_KEY=your-anthropic-api-key

# Comma-separated Telegram user IDs allowed to use the bot
ALLOWED_TELEGRAM_USERS=

# Timezone
TZ=Asia/Singapore