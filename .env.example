# App URL — your deployed Vercel URL (e.g., https://shared-calendar-delta.vercel.app)
# Must match the redirect URI registered in Google Cloud Console exactly.
# If not set, falls back to Vercel's built-in VERCEL_URL env var automatically.
APP_URL=https://your-app.vercel.app

# Google OAuth (from Google Cloud Console)
GOOGLE_CLIENT_ID=your-client-id-here
GOOGLE_CLIENT_SECRET=your-client-secret-here

# Google Calendar IDs
# Person 1 (you) — primary calendar used by the Telegram bot by default
CALENDAR_ID_1=your-email@gmail.com

# Person 2 (partner) — each calendar is fetched separately for the web view.
# Leave any of these blank to skip that calendar silently.
CALENDAR_ID_2_MAIN=partner-email@gmail.com
CALENDAR_ID_2_SOCIAL=
CALENDAR_ID_2_WORK=
CALENDAR_ID_2_CCA=

# Display names for each person
PERSON_1_NAME=You
PERSON_2_NAME=Partner

# Google OAuth tokens (obtained after login flow)
GOOGLE_ACCESS_TOKEN=
GOOGLE_REFRESH_TOKEN=

# Telegram Bot
TELEGRAM_BOT_TOKEN=your-telegram-bot-token

# Anthropic API key (for the Telegram bot's AI parsing)
ANTHROPIC_API_KEY=your-anthropic-api-key

# Comma-separated Telegram user IDs allowed to use the bot
ALLOWED_TELEGRAM_USERS=

# Telegram user → calendar routing
# Maps a Telegram user ID to the Google Calendar ID they write to.
# Format: TELEGRAM_USER_<telegram_user_id>_CALENDAR=<google_calendar_id>
# Get your Telegram user ID by messaging @userinfobot.
# If a user has no mapping, their events fall back to CALENDAR_ID_1.
TELEGRAM_USER_111111111_CALENDAR=your-email@gmail.com
TELEGRAM_USER_222222222_CALENDAR=partner-email@gmail.com

# Timezone
TZ=Asia/Singapore